#include "DlsAnnotation.idl"
#include "Pose.idl"
#include "Screw.idl"

module dls2_interface {
  					module msg {
								@Robot @Eigen
								struct TrajectoryGenerator
								{
									// Header
									string frame_id;
									unsigned long sequence_id;
									double timestamp;

									dls2_interface::msg::Pose com_pose;

									dls2_interface::msg::Screw com_vel;

									dls2_interface::msg::Screw com_acc;

									@JointState sequence<double> joints_position;
								    @JointState sequence<double> joints_velocity;
								    @JointState sequence<double> joints_acceleration;
								    @JointState sequence<double> joints_effort;
									@JointState sequence<double> kp;
									@JointState sequence<double> kd;

									double wrench[6];

									@LimbDataMap sequence<boolean> stance_legs;

									@LimbDataMap_EigenVector3 sequence<double> nominal_touch_down;
								    @LimbDataMap_EigenVector3 sequence<double> touch_down;
								    @LimbDataMap sequence<double> swing_period;

									@LimbDataMap sequence<double> normal_force_max;
									@LimbDataMap sequence<double> normal_force_min;
								};
					};
};